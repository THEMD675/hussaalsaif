# ============================================
# hussaalsaif.com -- Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# See docs/EMAIL_SETUP.md for step-by-step setup instructions.

# ------------------------------------------
# RESEND (Email sending via contact form)
# ------------------------------------------
# Get your API key at: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000/month
# Without this key, contact form falls back to Formsubmit.co
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender email address (must be on a domain verified in Resend)
# After verifying hussaalsaif.com in Resend, set to: inquiries@hussaalsaif.com
# Before domain verification, use: onboarding@resend.dev
RESEND_FROM_EMAIL=inquiries@hussaalsaif.com
